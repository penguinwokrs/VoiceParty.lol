# Copy to terraform.tfvars (gitignored) for LOCAL runs.
# In CI these come from GitHub Environment / repo secrets as TF_VAR_* instead.

# account_id has a default in variables.tf; override only if needed.
# account_id = "ded3682ef149b18dedb1e82650b1cda3"

# Required secrets (no defaults — a missing value errors instead of deleting
# the live env var). Set every one of these:
riot_game_api_key   = "..."
realtime_org_id     = "..."
realtime_api_key    = "..."
realtime_kit_app_id = "..."
cloud_flare_api_key = "..."

# Optional (absent on the live project while RSO is disabled):
# riot_client_id       = "..."
# riot_client_secret   = "..."
# riot_validation_enabled = "false"
