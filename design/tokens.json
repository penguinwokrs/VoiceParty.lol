{
  "$description": "VoiceParty design tokens (W3C DTCG format). Single source of truth for design values. Edit in Penpot (Import/Export > Design tokens JSON) or by hand, then run `pnpm tokens:build` to regenerate CSS variables + the MUI theme. One-way pipeline: tokens.json -> code. Theme: refined modern-gaming (LoL-inspired teal/gold on deep navy).",
  "color": {
    "brand": {
      "gold": { "$type": "color", "$value": "#C8AA6E" },
      "goldHover": { "$type": "color", "$value": "#F0E6D2" },
      "goldDark": { "$type": "color", "$value": "#785A28" },
      "teal": { "$type": "color", "$value": "#0AC8B9" },
      "tealHover": { "$type": "color", "$value": "#2DE0D2" },
      "tealDark": { "$type": "color", "$value": "#0A6E68" },
      "hextech": { "$type": "color", "$value": "#CDFAFA" }
    },
    "bg": {
      "base": { "$type": "color", "$value": "#0A1428" },
      "gradientTop": { "$type": "color", "$value": "#12233F" },
      "surface": { "$type": "color", "$value": "#101F38" },
      "surfaceHover": { "$type": "color", "$value": "#16294A" }
    },
    "border": {
      "subtle": { "$type": "color", "$value": "rgba(200, 170, 110, 0.18)" },
      "strong": { "$type": "color", "$value": "rgba(200, 170, 110, 0.38)" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#F0E6D2" },
      "secondary": { "$type": "color", "$value": "#A09B8C" },
      "muted": { "$type": "color", "$value": "rgba(240, 230, 210, 0.45)" }
    },
    "state": {
      "success": { "$type": "color", "$value": "#2FCB8A" },
      "error": { "$type": "color", "$value": "#E84057" }
    },
    "semantic": {
      "primary": { "$type": "color", "$value": "{color.brand.teal}" },
      "secondary": { "$type": "color", "$value": "{color.brand.gold}" }
    }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "shadow": {
    "card": { "$type": "shadow", "$value": "0 8px 30px rgba(0, 0, 0, 0.45)" },
    "glowTeal": { "$type": "shadow", "$value": "0 0 24px rgba(10, 200, 185, 0.35)" },
    "glowGold": { "$type": "shadow", "$value": "0 0 22px rgba(200, 170, 110, 0.30)" }
  },
  "font": {
    "family": {
      "base": { "$type": "fontFamily", "$value": "Roboto, system-ui, -apple-system, 'Segoe UI', sans-serif" },
      "display": { "$type": "fontFamily", "$value": "Roboto, system-ui, -apple-system, 'Segoe UI', sans-serif" }
    },
    "weight": {
      "regular": { "$type": "number", "$value": "400" },
      "medium": { "$type": "number", "$value": "500" },
      "bold": { "$type": "number", "$value": "700" },
      "black": { "$type": "number", "$value": "900" }
    }
  }
}
