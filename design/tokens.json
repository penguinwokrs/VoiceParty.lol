{
  "$description": "VoiceParty design tokens (W3C DTCG format). This file is the single source of truth for design values. Edit it in Penpot (Import/Export > Design tokens JSON) or by hand, then run `pnpm tokens:build` to regenerate the CSS variables and MUI theme consumed by the React app. The pipeline is one-way: tokens.json -> code.",
  "color": {
    "brand": {
      "gold": {
        "$type": "color",
        "$value": "#C8AA6E"
      },
      "goldHover": {
        "$type": "color",
        "$value": "#F0E6D2"
      },
      "goldDark": {
        "$type": "color",
        "$value": "#9E824C"
      },
      "teal": {
        "$type": "color",
        "$value": "#0AC8B9"
      },
      "tealHover": {
        "$type": "color",
        "$value": "#0FE0CE"
      },
      "hextech": {
        "$type": "color",
        "$value": "#CDFAFA"
      }
    },
    "bg": {
      "base": {
        "$type": "color",
        "$value": "#091428"
      },
      "elevated": {
        "$type": "color",
        "$value": "#1A2C4E"
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#F0E6D2"
      },
      "secondary": {
        "$type": "color",
        "$value": "#A09B8C"
      },
      "muted": {
        "$type": "color",
        "$value": "rgba(255, 255, 255, 0.3)"
      }
    },
    "semantic": {
      "primary": {
        "$type": "color",
        "$value": "{color.brand.teal}"
      },
      "secondary": {
        "$type": "color",
        "$value": "{color.brand.gold}"
      }
    }
  },
  "space": {
    "1": {
      "$type": "dimension",
      "$value": "4px"
    },
    "2": {
      "$type": "dimension",
      "$value": "8px"
    },
    "3": {
      "$type": "dimension",
      "$value": "12px"
    },
    "4": {
      "$type": "dimension",
      "$value": "16px"
    },
    "6": {
      "$type": "dimension",
      "$value": "24px"
    },
    "8": {
      "$type": "dimension",
      "$value": "32px"
    }
  },
  "radius": {
    "sm": {
      "$type": "dimension",
      "$value": "4px"
    },
    "md": {
      "$type": "dimension",
      "$value": "8px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "16px"
    }
  },
  "font": {
    "family": {
      "base": {
        "$type": "fontFamily",
        "$value": "Roboto, system-ui, -apple-system, sans-serif"
      },
      "display": {
        "$type": "fontFamily",
        "$value": "\"Beaufort\", \"Spiegel\", Roboto, serif"
      }
    }
  }
}
